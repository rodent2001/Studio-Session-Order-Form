<Window x:Class="StudioSessionCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudioSessionCalc"
        mc:Ignorable="d"
        Title="Music Studio Session Order Form"
        Width="400"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid
            x:Name="BannerHost"
            Grid.Row="0"
            >
            <Image
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Stretch="UniformToFill"
                Height="77"
                Source="/pics/_upper_banner.png"
                />
        </Grid>
        
        
        <Grid
            x:Name="PictureHost"
            Grid.Row="1"
            Grid.RowSpan="2"
            >
            <Image
                Grid.Row="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Stretch="UniformToFill"
                Height="{Binding ActualHeight, ElementName=PictureHost}"
                Source="/pics/_main_banner.png"
                />
        </Grid>
        

        <Border
            Grid.Row="0"
            />

        <Grid
            Grid.Row="1"
            x:Name="MainGrid"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition
                    x:Name="GridColumn1"
                    />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1">
                
            <!--<Image
                Source="/pics/_right_banner.png"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="Visible"
                />-->
            </Grid>

            <StackPanel
                Grid.Column="0"
                Margin="10,18,10,2"
                >
<!--****************-->
<!--Customer section-->
<!--****************-->
                <Label
                    Content="Customer"
                    Target="{Binding ElementName, XPath=CustomerComboBox}"
                    Padding="0"
                    />
                <Grid>
                    <ComboBox
                        x:Name="CustomerComboBox"
                        ItemsSource="{Binding Studio.StudioCustomers}"
                        DisplayMemberPath="CustomerName"
                        SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                        Margin="0,0,0,10"
                        />
                    <TextBlock
                        Text="--"
                        IsHitTestVisible="False"
                        Margin="5,2"
                        >
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CustomerComboBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border
                        BorderBrush="Red"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        Margin="0,0,0,10"
                        >
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"  Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomerWarningBorderActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
<!--****************************-->
<!--Session type/product section-->
<!--****************************-->
                <Label
                    Content="Session type"
                    Target="{Binding ElementName, XPath=SessionTypeComboBox}"
                    Padding="0"
                    />
                <Grid>
                    <ComboBox
                            x:Name="SessionTypeComboBox"
                            ItemsSource="{Binding Studio.StudioProducts}"
                            DisplayMemberPath="ProductName"
                            SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                            Margin="0,0,0,10"
                            />
                    <TextBlock
                            Text="--"
                            IsHitTestVisible="False"
                            Margin="5,2"
                            >
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=SessionTypeComboBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border
                        BorderBrush="Red"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        Margin="0,0,0,10"
                        >
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"  Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProductWarningBorderActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
<!--****************-->
<!--Duration section-->
<!--****************-->
                <Label
                    Content="Duration (hours)"
                    Target="{Binding ElementName, XPath=DurationComboBox}"
                    Padding="0"
                    />
                <Grid>
                    <ComboBox
                        x:Name="DurationComboBox"
                        ItemsSource="{Binding Studio.StudioSessionDurations}"
                        DisplayMemberPath="DurationHours"
                        SelectedItem="{Binding SelectedDuration, Mode=TwoWay}"
                        Margin="0,0,0,10"
                        />
                    <TextBlock
                            Text="--"
                            IsHitTestVisible="False"
                            Margin="5,2"
                            >
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=DurationComboBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Border
                        BorderBrush="Red"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        Margin="0,0,0,10"
                        >
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"  Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDurationWarningBorderActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
<!--*********************-->
<!--Cost per hour section-->
<!--*********************-->
                <Label
                    Content="Cost per hour (USD)"
                    Target="{Binding ElementName, XPath=CostPerHourTextBox}"
                    Padding="0"
                    />
                <Grid
                    Margin="0,0,0,10">
                    <TextBox
                        x:Name="CostPerHourTextBox"
                        Text="{Binding ProductCostPerHourText,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged
                                }"
                        Padding="2,2"
                        >
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=SessionTypeComboBox}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock
                        Text="select session type first"
                        Style="{StaticResource CostAndDiscountTextBlocksBase}"
                        >
                    </TextBlock>
                    <Border
                        BorderBrush="Red"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        >
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"  Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCostPerHourWarningBorderActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
<!--****************-->
<!--Discount section-->
<!--****************-->
                <Label
                    Content="Discount %"
                    Target="{Binding ElementName, XPath=DiscountTextBox}"
                    Padding="0"
                    />
                <Grid
                    Margin="0,0,0,15"
                    >
                    <TextBox
                        x:Name="DiscountTextBox"
                        Text="{Binding ProductCostDiscountText,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged
                                }"
                        Padding="2,2"
                        >
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=UrgentSurchargeCheckBox}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=SessionTypeComboBox}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock
                        Text="select session type first"
                        Style="{StaticResource CostAndDiscountTextBlocksBase}"
                        >
                    </TextBlock>
                    <Border
                        BorderBrush="Red"
                        BorderThickness="2"
                        IsHitTestVisible="False"
                        >
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"  Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCostDiscountWarningBorderActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style> 
                    </Border>
                </Grid>
<!--************************-->
<!--Urgent surcharge section-->
<!--************************-->
                <CheckBox
                    x:Name="UrgentSurchargeCheckBox"
                    IsChecked="{Binding IsUrgentSurchargeApplied, Mode=TwoWay}"
                    >
                    <CheckBox.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Urgent surcharge "/>
                            <TextBlock
                                Text="("
                                Style="{StaticResource UrgentSurchargeTextBlockBase}"
                                />
                            <TextBlock Text="{Binding SelectedProduct.ProductDefaultUrgentSurcharge}"/>
                            <TextBlock
                                Text="% up)"
                                Style="{StaticResource UrgentSurchargeTextBlockBase}"
                                />
                        </StackPanel>
                    </CheckBox.Content>
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Margin" Value="0,0,0,15"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text.Length, ElementName=DiscountTextBox}" Value="0">
                                    <Setter Property="IsEnabled" Value="True"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedItem, ElementName=SessionTypeComboBox}" Value="{x:Null}">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
<!--*************-->
<!--Total section-->
<!--*************-->
                <StackPanel
                    Orientation="Horizontal"
                    >
                    <TextBlock
                        Text="Total: $"
                        FontWeight="SemiBold"
                        />
                    <TextBlock
                        Text="{Binding OrderTotalCost, StringFormat={}{0:0.##}}"
                        FontWeight="SemiBold"
                        />
                </StackPanel>
<!--********************-->
<!--Save message section-->
<!--********************-->
                <TextBlock
                    Text="The order successfully saved!"
                    Foreground="Green"
                    Margin="0,10,0,0"
                    >
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Hidden"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAllOrderDataValidatedAfterLastChange}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
<!--***************-->
<!--Buttons section-->
<!--***************-->
        <StackPanel
            Orientation="Horizontal"
            Grid.Row="2"
            Margin="10"
            >
            <Button
                Content="Save order"
                VerticalAlignment="Top"
                Padding="5,1"
                Click="SaveOrderButton_Click"
                />
            <Border
                Width="10"
                />
            <Button
                Content="Reset data"
                VerticalAlignment="Top"
                Padding="5,1"
                Click="ResetDataButton_Click"
                />
        </StackPanel>
<!--**************-->
<!--Footer section-->
<!--**************-->
        <TextBlock
            Grid.Row="3"
            Text="Ilya Pashkov WPF demo application 2026 (c)"
            FontSize="9"
            Foreground="Gray"
            Margin="5,2"
            />
    </Grid>
</Window>
