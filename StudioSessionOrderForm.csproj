<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="pics\_main_banner.png" />
    <None Remove="pics\_right_banner.png" />
    <None Remove="pics\_upper_banner.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="pics\_main_banner.png" />
    <Resource Include="pics\_right_banner.png">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
    <Resource Include="pics\_upper_banner.png" />
  </ItemGroup>

</Project>
